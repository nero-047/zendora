NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase database and storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible alias if your Supabase project still labels it as anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRODUCT_IMAGE_BUCKET=product-images

# Optional server-only Supabase Storage S3 upload provider.
# If you set one S3 value, set all three required values.
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_S3_REGION=
# Optional. Defaults to https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_S3_ENDPOINT=
