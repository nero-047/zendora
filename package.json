{
  "name": "zendora",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "check:env": "node scripts/check-env.mjs",
    "check:deploy": "node scripts/check-env.mjs",
    "check:integrations": "node scripts/check-env.mjs --strict",
    "build": "next build",
    "package:eb": "node scripts/package-eb.mjs",
